{
  "name": "beme",
  "displayName": "Beme",
  "description": "Syntax highlighting for the beme language — M-expression syntax over Clojure.",
  "version": "0.4.0",
  "publisher": "xpojure-lang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xpojure-lang/vscode-beme.git"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "beme",
        "aliases": ["Beme", "beme"],
        "extensions": [".beme", ".meme"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "beme",
        "scopeName": "source.beme",
        "path": "./syntaxes/beme.tmLanguage.json"
      }
    ]
  }
}
